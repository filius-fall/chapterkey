# Core app settings
BOOKRAG_APP_NAME=ChapterKey
BOOKRAG_APP_SECRET=change-this-secret-before-deploying
BOOKRAG_ADMIN_USERNAME=admin
BOOKRAG_API_HOST=0.0.0.0
BOOKRAG_API_PORT=8000

# Storage paths
BOOKRAG_INPUT_DIR=./data/input_books
BOOKRAG_OUTPUT_DIR=./data/bookrag_output
BOOKRAG_DATA_DIR=./data/bookrag_output
BOOKRAG_UPLOADS_DIR=./data/bookrag_output/uploads
BOOKRAG_MANAGED_BOOKS_DIR=./data/bookrag_output/managed_books
BOOKRAG_VECTOR_DB_DIR=./data/bookrag_output/chroma_db
BOOKRAG_SQLITE_PATH=./data/bookrag_output/bookrag.sqlite3
BOOKRAG_WATCH_INTERVAL_SEC=10
BOOKRAG_MIN_FILE_AGE_SEC=30
BOOKRAG_AUTO_DELETE_SOURCE=true
BOOKRAG_DEFAULT_LIBRARY_NAME=Default Library

# Retrieval defaults
BOOKRAG_TOP_K=5
BOOKRAG_CHUNK_SIZE=750
BOOKRAG_CHUNK_OVERLAP=100

# Default provider names for local scan/watch/query
BOOKRAG_DEFAULT_EMBEDDING_PROVIDER_NAME=NVIDIA
BOOKRAG_DEFAULT_CHAT_PROVIDER_NAME=Ollama Local
BOOKRAG_DEFAULT_OCR_PROVIDER_NAME=

# Ollama local
BOOKRAG_OLLAMA_PROVIDER_NAME=Ollama Local
BOOKRAG_OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
BOOKRAG_OLLAMA_API_KEY=ollama
BOOKRAG_OLLAMA_EMBEDDING_MODEL=embeddinggemma
BOOKRAG_OLLAMA_CHAT_MODEL=
BOOKRAG_OLLAMA_OCR_MODEL=

# Ollama cloud or any OpenAI-compatible hosted endpoint
BOOKRAG_OLLAMA_CLOUD_PROVIDER_NAME=Ollama Cloud
BOOKRAG_OLLAMA_CLOUD_BASE_URL=
BOOKRAG_OLLAMA_CLOUD_API_KEY=
BOOKRAG_OLLAMA_CLOUD_EMBEDDING_MODEL=
BOOKRAG_OLLAMA_CLOUD_CHAT_MODEL=
BOOKRAG_OLLAMA_CLOUD_OCR_MODEL=

# OpenRouter
BOOKRAG_OPENROUTER_PROVIDER_NAME=OpenRouter
BOOKRAG_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
BOOKRAG_OPENROUTER_API_KEY=
BOOKRAG_OPENROUTER_EMBEDDING_MODEL=qwen/qwen3-embedding-8b
BOOKRAG_OPENROUTER_CHAT_MODEL=
BOOKRAG_OPENROUTER_OCR_MODEL=

# NVIDIA build.nvidia.com / NIM embeddings
BOOKRAG_NVIDIA_PROVIDER_NAME=NVIDIA
BOOKRAG_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
BOOKRAG_NVIDIA_API_KEY=
BOOKRAG_NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
BOOKRAG_NVIDIA_CHAT_MODEL=
BOOKRAG_NVIDIA_OCR_MODEL=

# MCP bridge settings when running the standalone MCP process
BOOKRAG_API_URL=http://127.0.0.1:8000
BOOKRAG_API_TOKEN=replace-with-token-from-login
